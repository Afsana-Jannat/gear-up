generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String        @id @default(uuid())
  name      String
  email     String        @unique
  password  String
  phone     String?
  address   String?
  avatar    String?
  role      Role          @default(CUSTOMER)
  status    UserStatus    @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  gearItems Gear[]        @relation("ProviderGear")
  rentals   RentalOrder[] @relation("CustomerRentals")
  reviews   Review[]      @relation("CustomerReviews")

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  gearItems   Gear[]

  @@map("categories")
}

model Gear {
  id           String           @id @default(uuid())
  name         String
  brand        String
  description  String
  pricePerDay  Decimal          @db.Decimal(10, 2)
  stock        Int
  availability GearAvailability @default(AVAILABLE)
  image        String?
  providerId   String
  categoryId   String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  category     Category         @relation(fields: [categoryId], references: [id])
  provider     User             @relation("ProviderGear", fields: [providerId], references: [id])
  rentalOrders RentalOrder[]
  reviews      Review[]

  @@map("gear")
}

model RentalOrder {
  id          String       @id @default(uuid())
  customerId  String
  gearId      String
  startDate   DateTime
  endDate     DateTime
  totalAmount Decimal      @db.Decimal(10, 2)
  status      RentalStatus @default(PLACED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  payment     Payment?
  customer    User         @relation("CustomerRentals", fields: [customerId], references: [id])
  gear        Gear         @relation(fields: [gearId], references: [id])
  review      Review?

  @@map("rental_orders")
}

model Payment {
  id            String        @id @default(uuid())
  transactionId String        @unique
  rentalOrderId String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  rentalOrder   RentalOrder   @relation(fields: [rentalOrderId], references: [id])

  @@map("payments")
}

model Review {
  id            String      @id @default(uuid())
  rating        Int
  comment       String?
  customerId    String
  gearId        String
  rentalOrderId String      @unique
  createdAt     DateTime    @default(now())
  customer      User        @relation("CustomerReviews", fields: [customerId], references: [id])
  gear          Gear        @relation(fields: [gearId], references: [id])
  rentalOrder   RentalOrder @relation(fields: [rentalOrderId], references: [id])

  @@map("reviews")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum GearAvailability {
  AVAILABLE
  OUT_OF_STOCK
}

enum RentalStatus {
  PLACED
  CONFIRMED
  PAID
  PICKED_UP
  RETURNED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  SSLCOMMERZ
}
